-
-        return res.json({ text: response.text ?? '' });
-    } catch (err) {
-        console.error('Erro Gemini (compare):', err?.message);
-        return res.status(500).json({ error: err?.message || 'Erro interno.' });
-    }
-});
-
-// ─── Proxy endpoint: Serviços similares ──────────────────────────────────────
